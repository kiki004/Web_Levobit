# Enable URL rewriting engine
RewriteEngine On
RewriteBase /

# ----------------------------------------------------------------------
# 1. Force removal of .html extension (clean URLs)
# ----------------------------------------------------------------------
# If the requested file does not exist as a directory but does exist as .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*?)/?$ $1.html [L]

# ----------------------------------------------------------------------
# 2. Redirect .html URLs to clean URLs (301, SEO friendly)
# ----------------------------------------------------------------------
RewriteCond %{THE_REQUEST} \.html[\ ?]
RewriteRule ^(.*)\.html$ /$1 [R=301,L]

# ----------------------------------------------------------------------
# 3. Redirect /index.html or /en/index.html to the directory root
# ----------------------------------------------------------------------
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^(.*)/index\.html$ /$1/ [R=301,L,NC]

RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\ HTTP/
RewriteRule ^(.*)index$ /$1 [R=301,L]

# ----------------------------------------------------------------------
# 4. Custom error page (404)
# ----------------------------------------------------------------------
ErrorDocument 404 /ro/404.html

# ----------------------------------------------------------------------
# 5. (Optional) Auto-redirect based on browser language (disable by default)
#    Uncomment the lines below if you want visitors to be redirected to
#    their language subfolder (e.g., /ro/...) when they visit the root.
# ----------------------------------------------------------------------
# RewriteCond %{REQUEST_URI} ^/?$ [OR]
# RewriteCond %{REQUEST_URI} ^/index\.html?$ [NC]
# RewriteCond %{HTTP:Accept-Language} ^ro [NC]
# RewriteRule ^$ /ro/ [R=301,L]
# 
# RewriteCond %{REQUEST_URI} ^/?$ [OR]
# RewriteCond %{REQUEST_URI} ^/index\.html?$ [NC]
# RewriteCond %{HTTP:Accept-Language} ^hu [NC]
# RewriteRule ^$ /hu/ [R=301,L]
# 
# # Default (English) if no match – already at root